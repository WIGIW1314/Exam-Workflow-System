{
  "name": "exam-workflow-system",
  "version": "1.0.0",
  "private": true,
  "description": "Exam workflow management system monorepo",
  "scripts": {
    "dev": "concurrently -k -n shared,server,client -c cyan,green,blue \"corepack pnpm --filter @exam-workflow/shared dev\" \"corepack pnpm --filter @exam-workflow/server dev\" \"corepack pnpm exec wait-on tcp:3200 && corepack pnpm --filter @exam-workflow/client dev\"",
    "build": "corepack pnpm -r build",
    "type-check": "corepack pnpm -r type-check",
    "db:generate": "corepack pnpm --filter @exam-workflow/server prisma:generate",
    "db:migrate": "corepack pnpm --filter @exam-workflow/server prisma:migrate",
    "db:seed": "corepack pnpm --filter @exam-workflow/server prisma:seed",
    "git:quick": "powershell -ExecutionPolicy Bypass -File ./scripts/git-quick-commit.ps1",
    "deploy:bt": "bash ./scripts/bt-deploy.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "wait-on": "^8.0.5"
  }
}
