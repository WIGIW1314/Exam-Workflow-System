{
  "name": "@exam-workflow/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server/src/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/src/app.js",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@exam-workflow/shared": "workspace:*",
    "@prisma/client": "^6.8.2",
    "@xmldom/xmldom": "^0.9.9",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "file-type": "^20.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.9.1",
    "multer": "^1.4.5-lts.2",
    "node-cron": "^4.2.1",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.1",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.8.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
